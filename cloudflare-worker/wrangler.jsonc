{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "morning-news-trigger",
  "main": "src/index.js",
  "compatibility_date": "2026-07-13",
  "workers_dev": true,
  "observability": {
    "enabled": true
  },
  "triggers": {
    "crons": [
      "52 5,6 * * *",
      "2,12,22 6,7 * * *"
    ]
  }
}
