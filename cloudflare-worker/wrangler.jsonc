{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "morning-news-trigger",
  "main": "src/index.js",
  "compatibility_date": "2026-07-13",
  "workers_dev": true,
  "observability": {
    "enabled": true
  },
  "triggers": {
    "crons": [
      "0,3,6,9,12,15,18,21,24,27,30 5,6 * * *"
    ]
  }
}
